---
// src/components/ParticleBackground.astro
// Client-only — rendered entirely in the browser
---

<canvas id="particle-canvas" class="fixed inset-0 pointer-events-none z-0" aria-hidden="true"></canvas>

<script>
  (function initParticles() {
    const canvas = document.getElementById('particle-canvas') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    // Respect reduced motion
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      canvas.style.display = 'none';
      return;
    }

    // Higher count on desktop
    const isMobile = window.innerWidth < 768;
    const PARTICLE_COUNT = isMobile ? 30 : 80;
    const CONNECT_DIST = 120;
    const MOUSE_RADIUS = 150;

    let W = window.innerWidth;
    let H = window.innerHeight;
    canvas.width = W;
    canvas.height = H;

    const mouse = { x: -1000, y: -1000 };
    window.addEventListener('mousemove', (e) => {
        mouse.x = e.clientX;
        mouse.y = e.clientY;
    });

    interface Particle {
      x: number;
      y: number;
      ox: number; // original x
      oy: number; // original y
      vx: number;
      vy: number;
      r: number;
      alpha: number;
      content?: string; // For code fragments
    }

    const codeFragments = ["if(active)", "process.env", "await signal()", "0xGHL", "flux", "=>", "{}", "debug", "logic"];

    const particles: Particle[] = Array.from({ length: PARTICLE_COUNT }, (_, i) => {
      const isCode = !isMobile && i % 10 === 0;
      return {
        x: Math.random() * W,
        y: Math.random() * H,
        ox: 0, oy: 0,
        vx: (Math.random() - 0.5) * 0.4,
        vy: (Math.random() - 0.5) * 0.4,
        r: isCode ? 0 : Math.random() * 1.5 + 0.5,
        alpha: Math.random() * 0.3 + 0.1,
        content: isCode ? codeFragments[Math.floor(Math.random() * codeFragments.length)] : undefined
      };
    });

    let animId: number;
    let isVisible = true;

    function draw() {
      if (!ctx || !isVisible) return;
      ctx.clearRect(0, 0, W, H);

      for (const p of particles) {
        // Movement
        p.x += p.vx;
        p.y += p.vy;

        // Bounce
        if (p.x < 0 || p.x > W) p.vx *= -1;
        if (p.y < 0 || p.y > H) p.vy *= -1;

        // Mouse Interactivity (Subtle push)
        const dx = mouse.x - p.x;
        const dy = mouse.y - p.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        
        if (dist < MOUSE_RADIUS) {
            const force = (MOUSE_RADIUS - dist) / MOUSE_RADIUS;
            p.x -= dx * force * 0.02;
            p.y -= dy * force * 0.02;
        }

        if (p.content) {
            ctx.font = '8px Space Mono';
            ctx.fillStyle = `rgba(20, 184, 166, ${p.alpha * 0.5})`;
            ctx.fillText(p.content, p.x, p.y);
        } else {
            ctx.beginPath();
            ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
            ctx.fillStyle = `rgba(0, 212, 255, ${p.alpha})`;
            ctx.fill();
        }
      }

      // Draw connections
      if (!isMobile) {
        for (let i = 0; i < particles.length; i++) {
          for (let j = i + 1; j < particles.length; j++) {
            if (particles[i].content || particles[j].content) continue; // Don't connect code
            const dx = particles[i].x - particles[j].x;
            const dy = particles[i].y - particles[j].y;
            const dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < CONNECT_DIST) {
              const lineAlpha = (1 - dist / CONNECT_DIST) * 0.1;
              ctx.beginPath();
              ctx.strokeStyle = `rgba(124, 58, 237, ${lineAlpha})`;
              ctx.lineWidth = 0.5;
              ctx.moveTo(particles[i].x, particles[i].y);
              ctx.lineTo(particles[j].x, particles[j].y);
              ctx.stroke();
            }
          }
        }
      }

      if (isVisible) {
          animId = requestAnimationFrame(draw);
      }
    }

    // Pause when tab is hidden (save battery/CPU)
    document.addEventListener('visibilitychange', () => {
      isVisible = !document.hidden;
      if (isVisible) {
          draw();
      } else {
          cancelAnimationFrame(animId);
      }
    });

    draw();

    let resizeTimer: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        W = window.innerWidth;
        H = window.innerHeight;
        canvas.width = W;
        canvas.height = H;
      }, 200);
    }, { passive: true });
  })();
</script>
