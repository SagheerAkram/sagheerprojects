---
// src/components/Preloader.astro
---
<div id="preloader">
  <div class="preloader-inner">
    <div class="preloader-bar"></div>
    <div class="preloader-label">SYSTEM_INITIALIZING</div>
  </div>
</div>

<style>
  #preloader {
    position: fixed;
    inset: 0;
    background: #020202;
    z-index: 99999;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.8s ease;
  }
  #preloader.done {
    opacity: 0;
    pointer-events: none;
  }
  .preloader-inner {
    text-align: center;
  }
  .preloader-bar {
    width: 240px;
    height: 1px;
    background: rgba(255,255,255,0.05);
    position: relative;
    margin-bottom: 16px;
    overflow: hidden;
  }
  .preloader-bar::after {
    content: '';
    position: absolute;
    top: 0; left: 0;
    height: 100%;
    width: 0%;
    background: #00f3ff;
    animation: barFill 1.4s cubic-bezier(0.16,1,0.3,1) 0.2s forwards;
  }
  .preloader-label {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.3em;
    color: #404040;
    text-transform: uppercase;
  }
  @keyframes barFill {
    from { width: 0% }
    to   { width: 100% }
  }
</style>

<script>
  window.addEventListener('load', () => {
    setTimeout(() => {
      const el = document.getElementById('preloader');
      if (el) {
        el.classList.add('done');
        setTimeout(() => el.remove(), 900);
      }
    }, 1800);
  });
</script>
