---
// src/components/CustomCursor.astro
// Hides the default cursor and replaces it with a custom dot and trailing ring.
---

 <div id="custom-cursor-dot" class="custom-cursor dot"></div>
<div id="custom-cursor-ring" class="custom-cursor ring"></div>

<style>
  /* Hide the default cursor globally */
  :global(html), :global(body), :global(a), :global(button), :global(input), :global(textarea), :global(select), :global(*) {
    cursor: none !important;
  }

  .custom-cursor {
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 99999;
    will-change: transform;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .dot {
    width: 6px;
    height: 6px;
    background-color: var(--accent-teal);
    border-radius: 50%;
    /* No transitions on transform for the dot - must be instant */
    transition: width 0.3s ease, height 0.3s ease, background-color 0.3s ease, opacity 0.3s ease;
  }

  .ring {
    width: 30px;
    height: 30px;
    border: 1px solid var(--accent-aurora);
    border-radius: 50%;
    opacity: 0.4;
    transition: width 0.3s ease, height 0.3s ease, border-color 0.3s ease, background-color 0.3s ease;
  }

  :global(.cursor-hover) .dot {
    transform: scale(2);
    background-color: var(--accent-aurora);
  }

  :global(.cursor-hover) .ring {
    width: 50px;
    height: 50px;
    border-color: var(--accent-teal);
    background-color: rgba(20, 184, 166, 0.05);
  }

  /* Fallback for devices without hover */
  @media (hover: none) {
    .custom-cursor {
      display: none !important;
    }
    :global(html), :global(body), :global(*) {
      cursor: auto !important;
    }
  }
</style>

<script>
  const dot = document.getElementById('custom-cursor-dot');
  const ring = document.getElementById('custom-cursor-ring');
  
  let mouseX = 0;
  let mouseY = 0;
  let ringX = 0;
  let ringY = 0;
  let isMoving = false;

  const updateCursor = (e) => {
    mouseX = e.clientX;
    mouseY = e.clientY;
    
    if (!isMoving) {
      isMoving = true;
      if (dot) dot.style.opacity = '1';
      if (ring) ring.style.opacity = '1';
    }

    // Dot is instant for perfect accuracy
    if (dot) {
      dot.style.transform = `translate3d(${mouseX - 3}px, ${mouseY - 3}px, 0)`;
    }
  };

  const lerp = (start, end, factor) => start + (end - start) * factor;

  const animate = () => {
    ringX = lerp(ringX, mouseX, 0.15);
    ringY = lerp(ringY, mouseY, 0.15);

    if (ring) {
      ring.style.transform = `translate3d(${ringX - 15}px, ${ringY - 15}px, 0)`;
    }

    requestAnimationFrame(animate);
  };

  window.addEventListener('mousemove', updateCursor);
  animate();

  // Hover states
  const handleMouseEnter = () => document.body.classList.add('cursor-hover');
  const handleMouseLeave = () => document.body.classList.remove('cursor-hover');

  const addListeners = () => {
    const interactables = document.querySelectorAll('a, button, .interactive');
    interactables.forEach(el => {
      el.addEventListener('mouseenter', handleMouseEnter);
      el.addEventListener('mouseleave', handleMouseLeave);
    });
  };

  addListeners();
  
  // Re-add listeners on Astro page loads if using View Transitions
  document.addEventListener('astro:after-swap', addListeners);

  document.addEventListener('mouseleave', () => {
    if (dot) dot.style.opacity = '0';
    if (ring) ring.style.opacity = '0';
  });

  document.addEventListener('mouseenter', () => {
    if (dot) dot.style.opacity = '1';
    if (ring) ring.style.opacity = '1';
  });
</script>
