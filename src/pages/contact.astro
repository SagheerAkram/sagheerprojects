---

<BaseLayout
  title="Contact — Sagheer"
  description="Get in touch with Sagheer. Email, Instagram, Threads, X, Discord."
>
  <!-- Blobs -->
  <div class="blob w-80 h-80 bg-electric-blue top-20 left-0 opacity-10"></div>
  <div class="blob w-72 h-72 bg-violet-glow bottom-32 right-0 opacity-10"></div>

  <section class="relative z-10 min-h-screen flex items-center justify-center px-6 py-32">
    <div class="w-full max-w-2xl page-enter">
      <!-- Header -->
      <div class="text-center mb-12">
        <span class="tag mb-4 inline-block">Contact</span>
        <h1 class="section-heading text-white mb-4">Let's Talk</h1>
        <p class="text-slate-400 leading-relaxed">
          Whether you have an idea, a project, or just want to say hi — I'm always open.
        </p>
      </div>

      <!-- Glass card -->
      <div class="glass rounded-3xl p-8 md:p-10 relative overflow-hidden">
        <!-- Subtle inner glow -->
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-48 h-1 bg-gradient-to-r from-transparent via-electric-blue to-transparent opacity-50 rounded-full"></div>

        <div class="space-y-4">
          {socials.map((social) => (
            <a
              href={social.href}
              target={social.href.startsWith('mailto') ? '_self' : '_blank'}
              rel="noopener noreferrer"
              class="social-row group flex items-center gap-4 p-4 rounded-2xl border border-white/5 bg-white/3 hover:bg-white/6 transition-all duration-300"
              style={`--accent: ${social.color}`}
            >
              <div
                class="social-icon w-11 h-11 rounded-xl flex items-center justify-center text-slate-400 transition-all duration-300 shrink-0"
                style={`color: ${social.color}; background: ${social.color}18;`}
              >
                <Fragment set:html={social.icon} />
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-xs text-slate-500 font-semibold tracking-widest uppercase mb-0.5">{social.name}</p>
                <p class="text-white font-medium truncate group-hover:text-white transition-colors">{social.handle}</p>
              </div>
              <svg
                width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                class="text-slate-600 group-hover:text-slate-300 group-hover:translate-x-1 transition-all duration-300 shrink-0"
              >
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          ))}
        </div>

        <!-- Bottom note -->
        <p class="text-center text-slate-600 text-xs mt-8">
          Usually respond within 24–48 hours. No spam, ever.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .social-row:hover {
    border-color: color-mix(in srgb, var(--accent) 30%, transparent);
    box-shadow: 0 0 20px color-mix(in srgb, var(--accent) 10%, transparent);
  }

  .social-row:hover .social-icon {
    box-shadow: 0 0 16px color-mix(in srgb, var(--accent) 40%, transparent);
  }
</style>
