---
// src/pages/404.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 // Page Not Found | Sagheer"
  description="This page doesn't exist."
>
  <section class="relative z-10 min-h-screen flex items-center justify-center px-6 text-center">
    <!-- Blobs -->
    <div class="blob w-72 h-72 bg-violet-glow top-20 left-1/4 opacity-10"></div>

    <div class="page-enter">
      <p class="text-8xl md:text-9xl font-black gradient-text mb-4 leading-none">404</p>
      <h1 class="text-2xl md:text-3xl font-bold text-white mb-4">Page not found</h1>
      <p class="text-slate-400 mb-10 max-w-md mx-auto">
        Either this page never existed, or it wandered off into the void. Either way, it's not here.
      </p>
      <div class="flex gap-4 items-center justify-center">
        <a href="/" class="btn-glow">Go Home</a>
        <a href="/projects" class="btn-outline">View Projects</a>
      </div>
    </div>
  </section>
</BaseLayout>
