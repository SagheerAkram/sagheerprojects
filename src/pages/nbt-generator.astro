---
// src/pages/nbt-generator.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="NBT Generator | Sagheer Akram"
  description="An AI-powered Minecraft NBT Generator and Editor for creating custom items, maps, and tools."
>
  <main class="relative min-h-screen pt-32 pb-24 px-4 md:px-8 lg:px-12 max-w-7xl mx-auto z-10">
    
    <header class="mb-16 reveal">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-8 h-px bg-accent-teal/50"></span>
        <span class="text-[10px] font-bold tracking-[0.3em] text-accent-teal uppercase">LAB EXPERIMENT 04</span>
      </div>
      <h1 class="text-5xl md:text-7xl font-black text-white tracking-tighter italic mb-4">
        Library of Chaos.
      </h1>
      <p class="text-slate-400 text-lg max-w-2xl font-light">
        Generate completely custom, overpowered Minecraft items. Powered by a massive database of 10,000+ illegal NBT blueprints, dynamically customized by AI.
      </p>
    </header>

    <div class="grid grid-cols-1 xl:grid-cols-12 gap-8">
      
      <!-- Input Section -->
      <section class="xl:col-span-4 flex flex-col gap-6 reveal" style="transition-delay: 100ms;">
        
        <!-- Describe the Item -->
        <div class="bg-white/[0.02] border border-white/5 rounded-3xl p-6">
          <label for="nbtPrompt" class="block text-sm font-bold tracking-widest text-slate-300 uppercase mb-4">
            The Librarian's Request
          </label>
          <textarea 
            id="nbtPrompt" 
            rows="5" 
            class="w-full bg-black/40 border border-white/10 rounded-xl p-4 text-white focus:outline-none focus:border-accent-teal/50 transition-colors placeholder:text-slate-600 resize-none text-sm"
            placeholder="e.g., I need a God Helmet named 'Crown of The Abyss'. Fill the rest of the slots with cool swords and custom fireworks."
          ></textarea>
        </div>

        <!-- Or Upload File to Database -->
        <div class="bg-white/[0.02] border border-white/5 rounded-3xl p-6">
          <label class="block text-sm font-bold tracking-widest text-slate-300 uppercase mb-2">
            Submit NBT to Database
          </label>
          <p class="text-xs text-slate-500 mb-4 font-light">
            Help grow the Library of Chaos! Upload your own highly-customized or illegal `.nbt` files. We will extract the exact data structure to train the AI.
          </p>
          <div class="flex items-center justify-center w-full">
            <label for="nbtUpload" class="flex flex-col items-center justify-center w-full h-24 border-2 border-accent-teal/20 border-dashed rounded-xl cursor-pointer hover:bg-accent-teal/[0.05] hover:border-accent-teal/50 transition-all">
                <div class="flex flex-col items-center justify-center">
                    <svg class="w-6 h-6 mb-2 text-accent-teal/50" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 20 16">
                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 13h3a3 3 0 0 0 0-6h-.025A5.56 5.56 0 0 0 16 6.5 5.5 5.5 0 0 0 5.207 5.021C5.137 5.017 5.071 5 5 5a4 4 0 0 0 0 8h2.167M10 15V6m0 0L8 8m2-2 2 2"/>
                    </svg>
                    <p class="text-xs text-slate-400" id="uploadText"><span class="font-semibold text-accent-teal">Click to upload</span> .nbt</p>
                </div>
                <input id="nbtUpload" type="file" class="hidden" accept=".nbt" />
            </label>
          </div>
        </div>

        <!-- Generate Button -->
        <button id="generateBtn" class="w-full py-4 bg-accent-teal text-black font-black tracking-widest uppercase rounded-xl hover:bg-white transition-colors flex justify-center items-center gap-2 group">
          <span>Forge Full Inventory</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="group-hover:translate-x-1 transition-transform stroke-current marker:stroke-width-3"><path d="m9 18 6-6-6-6" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>

        <!-- Status Message -->
        <div id="statusMessage" class="text-sm font-mono text-slate-400 bg-black/30 p-4 rounded-xl border border-white/5 hidden">
          > <span id="statusText" class="text-accent-teal">Ready.</span>
          <div id="progressContainer" class="w-full bg-white/10 h-1 mt-3 rounded-full overflow-hidden hidden">
            <div id="progressBar" class="bg-accent-teal h-full w-0 transition-all duration-300"></div>
          </div>
        </div>
      </section>

      <!-- Visualization Section -->
      <section class="xl:col-span-8 reveal" style="transition-delay: 200ms;">
        <div class="bg-[#1D1D1D] rounded-3xl p-6 border-4 border-[#3A3A3A] min-h-[500px] flex flex-col items-center relative shadow-2xl overflow-x-auto w-full">
          
          <div class="w-full flex justify-between items-center mb-8">
             <h2 class="text-[#AFAFAF] font-minecraft text-xl tracking-wider uppercase text-left">41-Slot Inventory</h2>
             <span class="text-xs text-slate-500 font-mono" id="selectedSlotInfo">Selected: None</span>
          </div>

          <!-- Minecraft 41-Slot UI -->
          <div class="mb-8 w-max flex flex-col sm:flex-row gap-4 justify-center items-start">
            
            <!-- Left Side: Armor & Offhand -->
            <div class="flex flex-row sm:flex-col gap-1 bg-[#353535] p-2 border-t-2 border-l-[#1e1e1e] border-t-[#1e1e1e] border-b-2 border-r-2 border-b-[#ffffff] border-r-[#ffffff] shadow-2xl">
               <div class="w-16 h-16 bg-[#8b8b8b] border-2 border-t-[#373737] border-l-[#373737] border-b-[#ffffff] border-r-[#ffffff] flex items-center justify-center relative cursor-pointer hover:bg-[#AFAFAF] transition-colors slot-ui" data-slotid="armor.helmet">
                  <div class="w-full h-full p-2 hidden item-icon"></div>
               </div>
               <div class="w-16 h-16 bg-[#8b8b8b] border-2 border-t-[#373737] border-l-[#373737] border-b-[#ffffff] border-r-[#ffffff] flex items-center justify-center relative cursor-pointer hover:bg-[#AFAFAF] transition-colors slot-ui" data-slotid="armor.chestplate">
                  <div class="w-full h-full p-2 hidden item-icon"></div>
               </div>
               <div class="w-16 h-16 bg-[#8b8b8b] border-2 border-t-[#373737] border-l-[#373737] border-b-[#ffffff] border-r-[#ffffff] flex items-center justify-center relative cursor-pointer hover:bg-[#AFAFAF] transition-colors slot-ui" data-slotid="armor.leggings">
                  <div class="w-full h-full p-2 hidden item-icon"></div>
               </div>
               <div class="w-16 h-16 bg-[#8b8b8b] border-2 border-t-[#373737] border-l-[#373737] border-b-[#ffffff] border-r-[#ffffff] flex items-center justify-center relative cursor-pointer hover:bg-[#AFAFAF] transition-colors slot-ui" data-slotid="armor.boots">
                  <div class="w-full h-full p-2 hidden item-icon"></div>
               </div>
               <div class="hidden sm:block my-2 w-full h-1 border-t-2 border-black/30"></div>
               <div class="ml-4 sm:ml-0 w-16 h-16 bg-[#8b8b8b] border-2 border-t-[#373737] border-l-[#373737] border-b-[#ffffff] border-r-[#ffffff] flex items-center justify-center relative cursor-pointer hover:bg-[#AFAFAF] transition-colors slot-ui" data-slotid="offhand">
                  <div class="w-full h-full p-2 hidden item-icon"></div>
               </div>
            </div>

            <!-- Right Side: Main Inv + Hotbar -->
            <div class="flex flex-col gap-4">
               <!-- Main 3x9 -->
               <div class="grid grid-cols-9 gap-1 bg-[#353535] p-2 border-t-2 border-l-[#1e1e1e] border-t-[#1e1e1e] border-b-2 border-r-2 border-b-[#ffffff] border-r-[#ffffff] shadow-2xl">
                  {Array.from({ length: 27 }).map((_, i) => (
                    <div class="w-12 h-12 md:w-14 md:h-14 lg:w-16 lg:h-16 bg-[#8b8b8b] border-2 border-t-[#373737] border-l-[#373737] border-b-[#ffffff] border-r-[#ffffff] flex items-center justify-center relative cursor-pointer hover:bg-[#AFAFAF] transition-colors slot-ui" data-slotid={`inventory.${i}`}>
                       <div class="w-full h-full p-1 lg:p-2 hidden item-icon"></div>
                    </div>
                  ))}
               </div>
               
               <!-- Hotbar 1x9 -->
               <div class="grid grid-cols-9 gap-1 bg-[#353535] p-2 border-t-2 border-l-[#1e1e1e] border-t-[#1e1e1e] border-b-2 border-r-2 border-b-[#ffffff] border-r-[#ffffff] shadow-2xl">
                  {Array.from({ length: 9 }).map((_, i) => (
                    <div class="w-12 h-12 md:w-14 md:h-14 lg:w-16 lg:h-16 bg-[#8b8b8b] border-2 border-t-[#373737] border-l-[#373737] border-b-[#ffffff] border-r-[#ffffff] flex items-center justify-center relative cursor-pointer hover:bg-[#AFAFAF] transition-colors slot-ui" data-slotid={`hotbar.${i}`}>
                       <div class="w-full h-full p-1 lg:p-2 hidden item-icon"></div>
                    </div>
                  ))}
               </div>
            </div>
            
            <!-- Global Tooltip (Hovering near mouse logic in JS) -->
            <div id="globalTooltip" class="fixed pointer-events-none z-50 bg-[#110111]/95 border-2 border-[#2b012b] p-4 text-white shadow-[0_0_20px_rgba(43,1,43,0.8)] hidden min-w-[200px] max-w-sm">
               <div class="text-[#55FFFF] font-minecraft text-lg mb-1" id="tooltipTitle">Unknown Item</div>
               <ul class="text-[#AAAAAA] font-minecraft text-sm space-y-1" id="tooltipLore"></ul>
            </div>
          </div>

          <!-- Raw SNBT Data View -->
          <div class="w-full mt-6 bg-black/50 rounded-xl p-4 border border-white/5 h-40 overflow-y-auto">
            <h3 class="text-xs font-bold tracking-widest text-slate-500 uppercase mb-2">Selected Item SNBT Output</h3>
            <pre><code id="snbtOutput" class="text-[10px] sm:text-xs text-accent-teal/80 font-mono whitespace-pre-wrap break-all">Click on a slot to view its raw NBT data here...</code></pre>
          </div>

          <!-- Download Action -->
          <div class="w-full mt-6 flex justify-end">
            <button id="downloadBtn" class="px-6 py-3 bg-white/5 border border-white/10 text-white font-bold tracking-widest text-sm uppercase rounded-lg hover:bg-white/10 hover:border-accent-teal/50 transition-all opacity-50 cursor-not-allowed" disabled>
              Download .NBT
            </button>
          </div>

        </div>
      </section>

    </div>
  </main>
</BaseLayout>

<style>
  @font-face {
    font-family: 'Minecraft';
    src: local('Minecraftia'), local('Minecraft'), sans-serif; 
  }
  .font-minecraft {
    font-family: 'Courier New', Courier, monospace; 
    line-height: 1.2;
    text-shadow: 2px 2px 0px #3F3F3F;
  }
  
  .slot-selected {
    outline: 3px solid white;
    outline-offset: -3px;
    z-index: 10;
  }

  @keyframes bounce-subtle {
    0%, 100% { transform: translateY(0) rotate(45deg); }
    50% { transform: translateY(-5px) rotate(45deg); }
  }
  .animate-bounce-subtle {
    animation: bounce-subtle 2s ease-in-out infinite;
  }
</style>

<script>
  import { parse } from 'prismarine-nbt';
  import { Buffer } from 'buffer';
  window.Buffer = Buffer;
  
  // DOM Elements
  const generateBtn = document.getElementById('generateBtn');
  const promptInput = document.getElementById('nbtPrompt');
  const snbtOutput = document.getElementById('snbtOutput');
  const statusMessage = document.getElementById('statusMessage');
  const statusText = document.getElementById('statusText');
  const downloadBtn = document.getElementById('downloadBtn');
  const globalTooltip = document.getElementById('globalTooltip');
  const tooltipTitle = document.getElementById('tooltipTitle');
  const tooltipLore = document.getElementById('tooltipLore');
  const selectedSlotInfo = document.getElementById('selectedSlotInfo');
  
  const progContainer = document.getElementById('progressContainer');
  const progBar = document.getElementById('progressBar');

  // Architecture defining all 41 slots requested
  const ALL_SLOTS = [
      "armor.helmet", "armor.chestplate", "armor.leggings", "armor.boots", "offhand",
      ...Array.from({length: 27}).map((_, i) => `inventory.${i}`),
      ...Array.from({length: 9}).map((_, i) => `hotbar.${i}`)
  ];

  // Store downloaded SNBT per slot ID
  let inventoryData = {};
  let selectedSlotId = null;

  function setStatus(msg, isError = false) {
    statusMessage.classList.remove('hidden');
    statusText.textContent = msg;
    statusText.className = isError ? 'text-red-400' : 'text-accent-teal';
  }

  function setProgress(percent) {
    progContainer.classList.remove('hidden');
    progBar.style.width = `${percent}%`;
    if(percent >= 100) setTimeout(() => progContainer.classList.add('hidden'), 1000);
  }

  function parseVisualsFromSnbt(snbt) {
    let name = "Chaos Item";
    let loreHtml = "";
    let itemId = "unknown_item";

    try {
        const idMatch = snbt.match(/id:\s*["'](?:minecraft:)?([^"']+)["']/);
        if (idMatch) itemId = idMatch[1];

        const nameMatch = snbt.match(/Name:\s*['"](.*?)['"]/);
        if (nameMatch) {
            const innerStr = nameMatch[1].replace(/\\"/g, '"');
            try {
                const nameJson = JSON.parse(innerStr);
                if (nameJson.text) name = nameJson.text;
                else if (Array.isArray(nameJson) && nameJson.length > 0 && nameJson[0].text) name = nameJson[0].text;
            } catch(e) { name = innerStr.replace(/\{"text":"([^"]+)"\}/g, "$1"); }
        }

        const enchMatch = snbt.match(/Enchantments:\s*\[(.*?)\]/);
        if (enchMatch) {
            const enchs = enchMatch[1].split('},{');
            enchs.forEach((e, idx) => {
                if (idx > 5) return; // Limit visual tooltips
                const idM = e.match(/id:\s*["']?(?:minecraft:)?([^"']+)["']?/);
                const lvlM = e.match(/lvl:\s*(-?\d+)/);
                if (idM && lvlM) {
                    const eName = idM[1].replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
                    loreHtml += `<li><span class="text-blue-400">${eName}</span> <span class="text-red-400">lvl ${lvlM[1]}</span></li>`;
                }
            });
            if (enchs.length > 5) loreHtml += `<li><span class="text-slate-500 italic">+ ${enchs.length - 5} more enchantments...</span></li>`;
        }
    } catch(e) {}
    return { name, loreHtml, itemId };
  }

  // Set up Mouse Tracking for Tooltip
  document.addEventListener('mousemove', (e) => {
      if (!globalTooltip.classList.contains('hidden')) {
          let x = e.clientX + 15;
          let y = e.clientY - 30;
          // Prevent screen overflow
          if (x + globalTooltip.offsetWidth > window.innerWidth) x = e.clientX - globalTooltip.offsetWidth - 15;
          if (y + globalTooltip.offsetHeight > window.innerHeight) y = window.innerHeight - globalTooltip.offsetHeight - 10;
          globalTooltip.style.left = `${x}px`;
          globalTooltip.style.top = `${y}px`;
      }
  });

  // Setup Slot Interactivity
  const slotElements = document.querySelectorAll('.slot-ui');
  slotElements.forEach(slotEl => {
      const slotId = slotEl.getAttribute('data-slotid');
      
      slotEl.addEventListener('mouseenter', () => {
          if (!inventoryData[slotId]) return;
          const visuals = parseVisualsFromSnbt(inventoryData[slotId]);
          tooltipTitle.textContent = visuals.name;
          tooltipLore.innerHTML = visuals.loreHtml || '<li class="text-[#555555]">No deep customization data known.</li>';
          globalTooltip.classList.remove('hidden');
      });
      
      slotEl.addEventListener('mouseleave', () => {
          globalTooltip.classList.add('hidden');
      });

      slotEl.addEventListener('click', () => {
          // Remove highlight from all
          slotElements.forEach(s => s.classList.remove('slot-selected'));
          slotEl.classList.add('slot-selected');
          
          selectedSlotId = slotId;
          selectedSlotInfo.textContent = `Selected: ${slotId}`;
          
          if (inventoryData[slotId]) {
              snbtOutput.textContent = inventoryData[slotId];
              downloadBtn.disabled = false;
              downloadBtn.classList.remove('opacity-50', 'cursor-not-allowed');
          } else {
              snbtOutput.textContent = "Empty slot.";
              downloadBtn.disabled = true;
              downloadBtn.classList.add('opacity-50', 'cursor-not-allowed');
          }
      });
  });

  function updateVisualStatusOfSlot(slotId, snbt) {
      const slotEl = document.querySelector(`.slot-ui[data-slotid="${slotId}"]`);
      if (!slotEl) return;
      
      inventoryData[slotId] = snbt;
      const iconContainer = slotEl.querySelector('.item-icon');
      if (!iconContainer) return;
      
      if (!snbt) {
          iconContainer.classList.add('hidden');
          return;
      }

      const visuals = parseVisualsFromSnbt(snbt);
      
      let iconColor = "bg-accent-teal/20";
      let iconContent = `<div class="w-2 h-2 sm:w-4 sm:h-4 bg-accent-teal/60 rounded-full shadow-[0_0_10px_rgba(45,212,191,0.5)]"></div>`;
      
      if (visuals.itemId.includes("sword") || visuals.itemId.includes("blade")) {
          iconColor = "bg-sky-400/20";
          iconContent = `<div class="w-1.5 sm:w-2 h-8 sm:h-12 bg-sky-200 rotate-45 rounded-sm relative shadow-[0_0_10px_rgba(0,0,0,0.5)]"><div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-4 h-2 bg-amber-900"></div></div>`;
      } else if (visuals.itemId.includes("helmet") || visuals.itemId.includes("chestplate") || visuals.itemId.includes("leggings") || visuals.itemId.includes("boots")) {
          iconColor = "bg-indigo-400/20";
          iconContent = `<div class="w-6 h-6 sm:w-10 sm:h-10 border-2 sm:border-4 border-indigo-200 bg-indigo-500/30 rounded-lg"></div>`;
      } else if (visuals.itemId.includes("rocket") || visuals.itemId.includes("firework")) {
          iconColor = "bg-red-400/20";
          iconContent = `<div class="w-2 h-6 sm:w-3 sm:h-8 bg-red-500 rounded-t-full relative shadow-[0_0_10px_rgba(239,68,68,0.8)]"><div class="absolute -bottom-2 left-1/2 -translate-x-1/2 w-1 h-3 bg-amber-800"></div></div>`;
      } else if (visuals.itemId.includes("egg")) {
          iconColor = "bg-green-400/20";
          iconContent = `<div class="w-4 h-5 sm:w-6 sm:h-8 bg-green-500 border border-green-800 rounded-full shadow-[inset_0_-3px_10px_rgba(0,0,0,0.5)] flex items-center justify-center"><div class="w-1 h-1 bg-green-800 rounded-full"></div></div>`;
      }

      iconContainer.innerHTML = `<div class="w-full h-full ${iconColor} flex items-center justify-center animate-bounce-subtle">${iconContent}</div>`;
      iconContainer.classList.remove('hidden');

      // Refresh text if currently selected
      if (selectedSlotId === slotId) {
          snbtOutput.textContent = snbt;
          downloadBtn.disabled = false;
          downloadBtn.classList.remove('opacity-50', 'cursor-not-allowed');
      }
  }

  // Generation Logic (Chunking)
  generateBtn.addEventListener('click', async () => {
    const prompt = promptInput.value.trim();
    if (!prompt) {
      setStatus("Please ask the Librarian for specific chaotic items.", true);
      return;
    }

    // Reset inventory
    inventoryData = {};
    slotElements.forEach(s => {
        const iconContainer = s.querySelector('.item-icon');
        if(iconContainer) iconContainer.classList.add('hidden');
    });

    generateBtn.classList.add('opacity-50', 'cursor-not-allowed');
    generateBtn.disabled = true;
    
    // Chunk strategy: We batch requests to not overload token outputs
    // Batch 1: Armor + Offhand
    const batch1 = ["armor.helmet", "armor.chestplate", "armor.leggings", "armor.boots", "offhand"];
    // Batch 2: Hotbar
    const batch2 = Array.from({length: 9}).map((_, i) => `hotbar.${i}`);
    // Batch 3: Inventory rows (can break into smaller if needed, let's do 1 large batch for 27 items since the text output per item isn't huge compared to 4096 tokens, but let's break it down to be safe)
    const batch3 = Array.from({length: 13}).map((_, i) => `inventory.${i}`);
    const batch4 = Array.from({length: 14}).map((_, i) => `inventory.${i + 13}`);

    const batches = [batch1, batch2, batch3, batch4];
    let completedBatches = 0;

    for (let batch of batches) {
        setStatus(`Librarian Retrieving Blueprints for Batch ${completedBatches + 1}/4...`);
        try {
            const response = await fetch('http://127.0.0.1:8001/api/generate-nbt', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ prompt: prompt, slots: batch })
            });

            const data = await response.json();
            if (!response.ok) throw new Error(data.details || data.error);

            // Update DOM as batch finishes
            if (data.items && typeof data.items === 'object' && !Array.isArray(data.items)) {
                // It's the new dictionary format {"slot.id": "snbt"}
                Object.entries(data.items).forEach(([slotId, snbtStr]) => {
                    updateVisualStatusOfSlot(slotId, snbtStr);
                });
            } else if (data.mapped_items) {
                 Object.entries(data.mapped_items).forEach(([slotId, snbtStr]) => {
                    updateVisualStatusOfSlot(slotId, snbtStr);
                });
            }

            completedBatches++;
            setProgress((completedBatches / batches.length) * 100);

        } catch (err) {
            console.error(err);
            setStatus(`Error on batch ${completedBatches + 1}: ${err.message}`, true);
            break; // Stop fetching further batches if one fails catastrophically
        }
    }

    if(completedBatches === batches.length) {
        setStatus(`Library of Chaos successfully mapped all 41 slots to your request!`);
    }
    
    generateBtn.classList.remove('opacity-50', 'cursor-not-allowed');
    generateBtn.disabled = false;
  });

  // Download functionality
  downloadBtn.addEventListener('click', () => {
    if (!selectedSlotId || !inventoryData[selectedSlotId]) return;
    const snbt = inventoryData[selectedSlotId];
    
    try {
        const blob = new Blob([snbt], { type: "text/plain" });
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        a.download = `chaotic_${selectedSlotId.replace('.','_')}.snbt`;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
        setStatus(`Exported ${selectedSlotId} SNBT blueprint!`);
    } catch (e) {
        setStatus("Export failed.", true);
    }
  });

  // Community Database (File Upload Visual Feedback)
  const nbtUpload = document.getElementById('nbtUpload');
  const uploadText = document.getElementById('uploadText');

  nbtUpload.addEventListener('change', async (e) => {
      const file = e.target.files[0];
      if (!file) return;

      uploadText.innerHTML = `Parsing <span class="font-semibold text-accent-teal">${file.name}</span>...`;
      setStatus(`Submitting ${file.name} to the Library of Chaos...`);
      uploadText.classList.add('animate-pulse');

      try {
          // Just read it to show interaction. Full database integration requires backend endpoint.
          const arrayBuffer = await file.arrayBuffer();
          const buffer = Buffer.from(arrayBuffer);
          await parse(buffer); // Verify it's valid NBT
          
          uploadText.classList.remove('animate-pulse');
          uploadText.innerHTML = `Successfully acquired <span class="font-semibold text-accent-teal">${file.name}</span>`;
          setStatus(`NBT Blueprint accepted! The Librarian will catalog this. (Note: Database injection in live server required)`);
      } catch (err) {
          uploadText.classList.remove('animate-pulse');
          uploadText.innerHTML = `<span class="text-red-400">Invalid .nbt file format.</span>`;
          setStatus("Failed to parse .nbt file. The Librarian rejects it.", true);
      }
  });

</script>
