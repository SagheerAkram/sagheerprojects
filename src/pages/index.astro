---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import { photos } from '../data/photography.js';
import ExamStatus from '../components/ExamStatus.astro';

const previewPhotos = photos.slice(0, 6);
---

<BaseLayout
  title="Sagheer Akram // Student Researcher. AI Experimenter."
  description="Personal creative lab of Sagheer Akram. Exploring the intersection of AI, code, and visual narratives."
>
  <!-- HERO -->
  <section class="relative min-h-[90vh] flex items-center px-8 md:px-16 pt-28 pb-16 overflow-hidden">
    <div class="relative z-10 max-w-5xl" id="hero-content">
      <!-- Eyebrow -->
      <div class="flex items-center gap-3 reveal">
        <span class="w-8 h-px bg-accent-teal/30"></span>
        <span class="text-[10px] font-bold tracking-[0.3em] text-accent-teal uppercase">EST. 2025 · PERSONAL LAB</span>
      </div>

      <!-- Real-time Developer Status -->
      <div class="mt-6 reveal">
        <ExamStatus />
      </div>

      <!-- Main heading -->
      <h1 class="text-6xl md:text-9xl font-black text-white tracking-tighter leading-[0.85] mt-8 reveal">
        Sagheer Akram
        <span class="block text-xl md:text-3xl font-light tracking-widest text-slate-500 mt-6 lowercase">making code feel a bit more human.</span>
      </h1>

      <!-- Description -->
      <p class="text-slate-400 text-lg md:text-xl leading-relaxed mb-12 max-w-2xl mt-12 reveal">
        I’m a student researcher who spends too much time thinking about how logic connects to nature. 
        Whether it's AI that actually talks back or code that lives in the shadows, 
        this is where I document my late-night experiments.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:row gap-12 items-start reveal">
        <a href="/projects" class="group flex items-center gap-4 text-white font-bold tracking-tighter text-xl hover:text-accent-teal transition-colors">
          Explore the Archive
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="group-hover:translate-x-2 transition-transform opacity-40"><path d="m9 18 6-6-6-6"/></svg>
        </a>
        <a href="/photography" class="group flex items-center gap-4 text-white font-bold tracking-tighter text-xl hover:text-accent-teal transition-colors">
          Visual Memories
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="group-hover:translate-x-2 transition-transform opacity-40"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-20">
      <div class="w-px h-12 bg-gradient-to-b from-accent-ice to-transparent"></div>
    </div>
  </section>

  <!-- FEATURED WORK -->
  <section class="relative z-10 max-w-6xl mx-auto px-6 py-32">
    <div class="flex items-end justify-between mb-20 reveal">
      <div>
        <h2 class="text-4xl md:text-6xl font-black text-white tracking-tighter mb-4 italic">Recent Logs.</h2>
        <p class="text-slate-500 max-w-md font-light">The stuff I've been breaking and fixing lately.</p>
      </div>
      <a href="/projects" class="text-xs font-bold tracking-widest text-slate-500 hover:text-accent-teal transition-colors uppercase border-b border-white/10 pb-1 hidden sm:block">Open Archive</a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      {[
        { title: 'OmniShell', desc: 'Secure communication that doesn’t care about central servers.', slug: 'omnishell' },
        { title: 'QuickCmd', desc: 'An AI that understands my intent without taking over my machine.', slug: 'quickcmd' },
        { title: 'ATLAS',     desc: 'Mapping out the gravity of my codebases in 3D.', slug: 'atlas' },
      ].map((item) => (
        <a href={`/projects/${item.slug}`} class="group relative block p-8 rounded-3xl bg-white/[0.01] border border-white/[0.03] hover:border-accent-teal/20 transition-all duration-700 hover:bg-white/[0.02]">
          <h3 class="text-2xl font-black text-white mb-4 group-hover:text-accent-teal transition-colors tracking-tight italic">{item.title}</h3>
          <p class="text-slate-500 text-sm leading-relaxed mb-8">{item.desc}</p>
          <div class="text-[10px] font-bold tracking-[0.2em] uppercase text-slate-600 group-hover:text-accent-teal transition-colors">Read Log</div>
        </a>
      ))}
    </div>
  </section>

  <!-- PHOTOGRAPHY TEASER -->
  <section class="relative z-10 max-w-6xl mx-auto px-6 py-32">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-20 items-center">
      <div class="lg:col-span-12 mb-12 reveal">
        <h2 class="text-4xl md:text-6xl font-black text-white tracking-tighter italic mb-8">Through the Lens.</h2>
        <p class="text-slate-400 leading-relaxed text-lg max-w-2xl font-light">
          When the screen gets too loud, I take my camera outside. 
          There's a specific kind of logic in how light hits a mossy rock 
          or how a city falls silent at 3 AM. This is my way of capturing that.
        </p>
      </div>
      
      <div class="lg:col-span-12 grid grid-cols-2 md:grid-cols-4 gap-6 reveal">
        {previewPhotos.slice(0, 4).map((photo) => (
          <div class="aspect-[3/4] rounded-2xl overflow-hidden bg-white/5 group border border-white/5">
            <img 
              src={photo.src} 
              alt={photo.title} 
              class="w-full h-full object-cover grayscale opacity-40 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-1000 scale-100 group-hover:scale-105" 
              loading="lazy" 
            />
          </div>
        ))}
      </div>

      <div class="lg:col-span-12 text-center mt-12 reveal">
        <a href="/photography" class="inline-block text-white font-bold tracking-tighter text-2xl hover:text-accent-teal transition-colors">
            Look at the full gallery
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
