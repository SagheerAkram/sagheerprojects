---
// src/pages/projects/[slug].astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { projects } from '../../data/projects.js';

export async function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<BaseLayout 
  title={`${project.title} — Sagheer Akram`}
  description={project.summary}
>
  <!-- Mermaid Support -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/mermaid/dist/mermaid.min.js"></script>
  <script is:inline>
    document.addEventListener('astro:page-load', () => {
      mermaid.initialize({ 
        startOnLoad: true,
        theme: 'dark',
        themeVariables: {
          primaryColor: '#14b8a6',
          primaryTextColor: '#fff',
          lineColor: '#14b8a6',
          secondaryColor: '#2d5a27',
          tertiaryColor: '#050b0a'
        }
      });
      mermaid.contentLoaded();
    });
  </script>

  <article class="relative z-10 pt-32 pb-24 px-6 max-w-5xl mx-auto">
    
    <!-- Project Header -->
    <header class="mb-16">
      <div class="flex items-center gap-4 mb-6 reveal">
        <span class="px-3 py-1 rounded-full bg-white/[0.05] border border-white/[0.1] text-xs font-mono text-accent-teal uppercase tracking-widest">
          {project.category}
        </span>
        <span class="text-xs font-mono text-slate-500 uppercase tracking-widest">
          STATUS: {project.status || 'LOGGED'}
        </span>
      </div>
      
      <h1 class="text-5xl md:text-8xl font-black text-white tracking-tighter mb-8 reveal">
        {project.title}
      </h1>
      
      <div class="grid md:grid-cols-3 gap-12 border-t border-white/[0.05] pt-12">
        <div class="md:col-span-2 reveal">
          <p class="text-xl md:text-2xl text-slate-300 leading-relaxed font-light">
            {project.overview}
          </p>
        </div>
        <div class="space-y-8 reveal">
          <div>
            <h3 class="text-xs uppercase tracking-[0.2em] text-slate-500 mb-3">Core Stack</h3>
            <div class="flex flex-wrap gap-2">
              {project.tags.map(tag => (
                <span class="text-sm text-white/70 font-mono italic">#{tag}</span>
              ))}
            </div>
          </div>
          {project.github && (
            <a 
              href={project.github} 
              target="_blank" 
              class="inline-flex items-center gap-2 text-accent-teal hover:gap-4 transition-all duration-300 group"
            >
              <span class="font-bold tracking-tight">VIEW SOURCE</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-60 group-hover:opacity-100"><path d="M7 7h10v10"></path><path d="M7 17 17 7"></path></svg>
            </a>
          )}
        </div>
      </div>
    </header>

    <!-- Visual Showcase / Interactive Block -->
     <section class="mb-24 rounded-3xl overflow-hidden bg-white/[0.02] border border-white/[0.05] aspect-video relative group reveal">
        <div class={`absolute inset-0 transition-opacity duration-1000 opacity-40 group-hover:opacity-60 bg-cover bg-center ${project.bannerGradient}`} style={`background-image: url(${project.image})`}></div>
        <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent opacity-60"></div>
        
        <div class="absolute inset-0 flex items-center justify-center p-8 md:p-16">
            <!-- Terminal Animation for OmniShell -->
            {project.showcaseType === 'terminal-p2p' && (
                <div class="w-full max-w-2xl bg-black/80 rounded-xl border border-accent-teal/30 p-6 font-mono text-sm overflow-hidden shadow-2xl shadow-accent-teal/5">
                    <div class="flex gap-2 mb-4 border-b border-white/5 pb-2">
                        <div class="w-2 h-2 rounded-full bg-red-500/50"></div>
                        <div class="w-2 h-2 rounded-full bg-yellow-500/50"></div>
                        <div class="w-2 h-2 rounded-full bg-green-500/50"></div>
                        <span class="text-[10px] text-slate-600 ml-2">omnishell_daemon_v0.4</span>
                    </div>
                    <div class="space-y-1 text-accent-teal/80">
                        <p class="text-slate-500">[SYSTEM] Initializing DH-KEA Exchange...</p>
                        <p class="text-slate-500">[SYSTEM] Key verified. Buffer established.</p>
                        <p class="typing-text">Sagheer: Send encrypted packet 0xA4...</p>
                        <p class="text-slate-400 opacity-0 animate-delay-1 whitespace-pre">Remote: [REDACTED BY AES-256]</p>
                        <p class="text-accent-aurora animate-pulse mt-4">&gt; Listening on port 4433...</p>
                    </div>
                </div>
            )}

            <!-- Graph Animation Placeholder for ATLAS -->
            {project.showcaseType === 'graph-visualization' && (
                <div class="relative w-full h-full flex items-center justify-center">
                    <div class="absolute inset-0 flex items-center justify-center opacity-20">
                        <div class="w-64 h-64 rounded-full border border-accent-teal border-dashed animate-spin-slow"></div>
                        <div class="absolute w-48 h-48 rounded-full border border-accent-aurora border-dashed animate-reverse-spin"></div>
                    </div>
                    <div class="text-center z-10">
                        <p class="text-xs font-mono text-accent-teal mb-2 uppercase tracking-[0.5em]">Mapping Architecture</p>
                        <h3 class="text-3xl font-black text-white italic">VISUAL GRAVITY</h3>
                    </div>
                </div>
            )}

             <!-- Default for others -->
             {!project.showcaseType && (
                 <div class="text-center">
                    <p class="text-sm font-mono text-slate-500 mb-4 tracking-[0.3em]">NO VISUAL LOGS FOUND</p>
                    <div class="w-32 h-1 bg-white/5 mx-auto rounded-full overflow-hidden">
                        <div class="w-1/2 h-full bg-accent-teal animate-shimmer"></div>
                    </div>
                 </div>
             )}
        </div>
    </section>

    <!-- Research Logs & Diagrams -->
    <div class="grid md:grid-cols-5 gap-16 mb-24">
      
      <!-- Content Sidebar -->
      <aside class="md:col-span-2 space-y-16">
        <div class="reveal">
          <h2 class="text-xs uppercase tracking-[0.3em] text-slate-500 mb-8 border-b border-white/5 pb-4 italic">RESEARCH LOGS</h2>
          <div class="space-y-8">
            {project.researchLogs?.map((log, i) => (
              <div class="relative pl-8 border-l border-accent-teal/20 py-1">
                <span class="absolute -left-[5px] top-0 w-2 h-2 rounded-full bg-accent-teal/40"></span>
                <p class="text-sm text-slate-400 leading-relaxed italic">
                    "{log}"
                </p>
              </div>
            ))}
          </div>
        </div>
      </aside>

      <!-- Main Case Study Content -->
      <div class="md:col-span-3 space-y-16">
        <section class="reveal">
          <h2 class="text-2xl font-bold text-white mb-6">The Intent</h2>
          <p class="text-slate-400 leading-relaxed text-lg">
            {project.problem}
          </p>
        </section>

        <!-- Dynamic Mermaid Diagram -->
        <section class="p-8 rounded-2xl bg-white/[0.02] border border-white/[0.05] reveal">
            <h3 class="text-xs font-mono text-slate-500 mb-8 tracking-[0.3em] uppercase">System Schematic</h3>
            <div class="mermaid opacity-60 hover:opacity-100 transition-opacity duration-500">
                {project.slug === 'omnishell' && `
                graph TD
                    A[Source Node] -->|RSA-Handshake| B(P2P Bridge)
                    B -->|Encrypted Payload| C{Transport Layer}
                    C -->|Tor| D[Onion Network]
                    C -->|BLE| E[Local Peer]
                    D --> F[Destination]
                    E --> F
                `}
                {project.slug === 'quickcmd' && `
                graph LR
                    A[User Note] -->|interpreted by| B(QuickCmd)
                    B -->|query| C[LLM API]
                    C -->|suggested cmd| D{Approval Prompt}
                    D -->|Verified| E[Execution]
                    D -->|Decline| F[Refine]
                    E -->|Optional| G[Docker Sandbox]
                `}
                {project.slug === 'atlas' && `
                graph TD
                    A[File Scanner] --> B[AST Parser]
                    B --> C[Dependency Map]
                    C --> D(PageRank Engine)
                    D --> E[D3 Force Graph]
                    E --> F[3D Three.js Scene]
                `}
                 {project.slug === 'code-archaeologist' && `
                graph TD
                    A[Legacy Code] --> B[FAISS Index]
                    B --> C[Intent Decoder]
                    C --> D{Query Interface}
                    D -->|RAG| E[Explanation]
                    E --> F[Human Understanding]
                `}
            </div>
        </section>

        <section class="reveal">
          <h2 class="text-2xl font-bold text-white mb-6">The Build</h2>
          <p class="text-slate-400 leading-relaxed text-lg">
            {project.solution}
          </p>
        </section>

        <section class="reveal">
          <h2 class="text-2xl font-bold text-white mb-6">Reflections</h2>
          <p class="text-slate-400 leading-relaxed text-lg">
            {project.learned}
          </p>
        </section>
      </div>
    </div>

    <!-- Contact CTA -->
    <footer class="text-center py-24 border-t border-white/[0.05] reveal">
        <p class="text-slate-500 mb-8 font-mono text-sm tracking-[0.2em]">END OF LOG</p>
        <a href="/contact" class="inline-block text-3xl font-black text-white hover:text-accent-teal transition-colors">
            Got thoughts? Let's talk.
        </a>
    </footer>

  </article>

  <style>
    .typing-text {
        border-right: 2px solid var(--accent-teal);
        white-space: nowrap;
        overflow: hidden;
        width: 0;
        animation: typing 2.5s steps(30, end) forwards, blink 0.5s step-end infinite;
    }

    @keyframes typing {
        from { width: 0 }
        to { width: 100% }
    }

    @keyframes blink {
        50% { border-color: transparent }
    }

    .animate-delay-1 {
        animation: fadeIn 0.5s ease 2.8s forwards;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(5px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .animate-spin-slow {
        animation: spin 20s linear infinite;
    }
    
    .animate-reverse-spin {
        animation: spin-reverse 15s linear infinite;
    }

    @keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    @keyframes spin-reverse {
        from { transform: rotate(360deg); }
        to { transform: rotate(0deg); }
    }

    .animate-shimmer {
        animation: shimmer 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }

    @keyframes shimmer {
        0%, 100% { transform: translateX(-100%); }
        50% { transform: translateX(100%); }
    }
  </style>

  <script>
    // Reveal script for project page
    const revealElements = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
        if (entry.isIntersecting) {
            (entry.target as HTMLElement).style.opacity = '1';
            (entry.target as HTMLElement).style.transform = 'translateY(0)';
        }
        });
    }, { threshold: 0.1 });

    revealElements.forEach((el) => {
        (el as HTMLElement).style.opacity = '0';
        (el as HTMLElement).style.transform = 'translateY(20px)';
        (el as HTMLElement).style.transition = 'all 0.8s cubic-bezier(0.16, 1, 0.3, 1)';
        observer.observe(el);
    });
  </script>
</BaseLayout>
