---
// src/pages/about.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About — Sagheer Akram"
  description="Student, researcher, and observer of digital patterns. Exploring AI, code, and the moments in between."
>
  <section class="relative z-10 max-w-4xl mx-auto px-6 pt-32 pb-24">

    <!-- Header -->
    <div class="mb-20">
      <span class="hero-eyebrow tracking-[0.3em] text-accent-ice opacity-60">CS STUDENT // NIGHT OWL // LATE NIGHT BUILDER</span>
      <h1 class="text-5xl md:text-7xl font-black text-white tracking-tighter leading-none mt-6 mb-10">
        I break things just to see<br/>how they fit back together.
      </h1>
      <p class="text-slate-400 max-w-2xl leading-relaxed text-lg md:text-xl">
        I'm Sagheer. Most of my day is spent staring at a terminal, trying to convince a machine to see the world the way I do. I'm not here to change the world—I'm here to understand it, one line of code at a time.
      </p>
    </div>

    <!-- Philosophy -->
    <div class="grid md:grid-cols-2 gap-12 mb-24">
      <div class="reveal">
        <h2 class="text-white font-bold text-xl mb-4 tracking-tight">The 3 AM Curiosity</h2>
        <p class="text-slate-400 leading-relaxed">
          There’s a specific kind of quiet that only happens late at night. That’s when I do my best work. It’s not about being "productive"—it’s about following a thread of curiosity until it leads somewhere interesting. Whether it's AI logic or a simple automation script, I love the raw honesty of a working system.
        </p>
      </div>
      <div class="reveal">
        <h2 class="text-white font-bold text-xl mb-4 tracking-tight">Nature & Logic</h2>
        <p class="text-slate-400 leading-relaxed">
          I've always found it weird how similar tree roots look to network diagrams. Nature is just a massive, complex system that doesn't need a manual. I try to bring that same organic feeling to the code I write. It should feel intentional, quiet, and reliable.
        </p>
      </div>
    </div>

    <!-- Stats/Quick Facts - Refined -->
    <div class="mb-24 py-12 border-y border-white/[0.05] reveal">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {[
          { label: 'Currently', value: 'Learning CS' },
          { label: 'Tools', value: 'AI / Python / Web' },
          { label: 'Motto', value: 'Stay Curious' },
          { label: 'Energy', value: 'Strong Coffee' },
        ].map((stat) => (
          <div>
            <p class="text-xs uppercase tracking-widest text-slate-500 mb-2">{stat.label}</p>
            <p class="text-lg font-bold text-accent-ice tracking-tight">{stat.value}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Exploring -->
    <div class="reveal">
      <h2 class="text-2xl font-bold text-white mb-8 tracking-tight">What I'm Messing With</h2>
      <div class="space-y-6">
        {[
          { title: 'AI Automation', desc: 'Making tools that actually help. Not just chatbots, but systems that can handle the boring stuff so I can focus on building.' },
          { title: 'Terminal Experiments', desc: 'I love the command line. Building things like OmniShell—secure, fast, and minimal communication tools.' },
          { title: 'Visual Systems', desc: 'Trying to make data look as beautiful as it is complex. Dark modes, subtle glows, and clean typography.' },
        ].map((item) => (
          <div class="group p-6 rounded-2xl bg-white/[0.02] border border-white/[0.05] hover:border-accent-ice/20 transition-all duration-500">
            <h3 class="text-white font-bold mb-2 group-hover:text-accent-ice transition-colors">{item.title}</h3>
            <p class="text-slate-500 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>

  </section>
</BaseLayout>

<script>
  // Simple scroll reveals
  const revealElements = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        (entry.target as HTMLElement).style.opacity = '1';
        (entry.target as HTMLElement).style.transform = 'translateY(0)';
      }
    });
  }, { threshold: 0.1 });

  revealElements.forEach((el) => {
    (el as HTMLElement).style.opacity = '0';
    (el as HTMLElement).style.transform = 'translateY(20px)';
    (el as HTMLElement).style.transition = 'all 0.8s cubic-bezier(0.16, 1, 0.3, 1)';
    observer.observe(el);
  });
</script>
