---
// src/pages/about.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About — Sagheer Akram"
  description="Student, researcher, and observer of digital patterns. Exploring AI, code, and the moments in between."
>
  <section class="relative z-10 max-w-4xl mx-auto px-6 pt-32 pb-24">

    <!-- Header -->
    <div class="mb-20">
      <span class="hero-eyebrow tracking-[0.3em] text-accent-ice opacity-60">RESEARCHER // STUDENT</span>
      <h1 class="text-5xl md:text-7xl font-black text-white tracking-tighter leading-none mt-6 mb-10">
        Obsessed with the<br/>"How" and "Why".
      </h1>
      <p class="text-slate-400 max-w-2xl leading-relaxed text-lg md:text-xl">
        I spend a lot of time thinking about how things work. Not just the code, but the intention behind it. 
        I’m a student, a researcher, and someone who probably drinks too much coffee while chasing a bug at 4 AM.
      </p>
    </div>

    <!-- Philosophy -->
    <div class="grid md:grid-cols-2 gap-12 mb-24">
      <div class="reveal">
        <h2 class="text-white font-bold text-xl mb-4 tracking-tight">The Human Element</h2>
        <p class="text-slate-400 leading-relaxed">
          I believe technology should feel human. It shouldn't just be about efficiency—it should be about curiosity. 
          I like building things that have a bit of mystery to them, tools that reveal their value over time rather 
          than screaming for attention.
        </p>
      </div>
      <div class="reveal">
        <h2 class="text-white font-bold text-xl mb-4 tracking-tight">Beyond the Screen</h2>
        <p class="text-slate-400 leading-relaxed">
          When I’m not at a keyboard, I’m usually out with a camera or somewhere quiet, trying to disconnect. 
          The best ideas usually come when you aren't looking for them. Photography is how I slow down 
          the world enough to actually see it.
        </p>
      </div>
    </div>

    <!-- Stats/Quick Facts - Refined -->
    <div class="mb-24 py-12 border-y border-white/[0.05] reveal">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {[
          { label: 'Status', value: 'Student' },
          { label: 'Obsession', value: 'AI Tools' },
          { label: 'Score', value: '100% CS' },
          { label: 'Focus', value: 'Systems' },
        ].map((stat) => (
          <div>
            <p class="text-xs uppercase tracking-widest text-slate-500 mb-2">{stat.label}</p>
            <p class="text-lg font-bold text-accent-ice tracking-tight">{stat.value}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Exploring -->
    <div class="reveal">
      <h2 class="text-2xl font-bold text-white mb-8 tracking-tight">Current Trajectories</h2>
      <div class="space-y-6">
        {[
          { title: 'AI Logic & Reasoning', desc: 'Understanding how large models process information and building safe, vetted interfaces for terminal execution.' },
          { title: 'Architectural Gravity', desc: 'Visualizing how files and dependencies interact to create the "gravity" of a massive codebase.' },
          { title: 'Visual Artifacts', desc: 'Experimenting with minimal design systems that prioritize focus and emotional resonance over loud neons.' },
        ].map((item) => (
          <div class="group p-6 rounded-2xl bg-white/[0.02] border border-white/[0.05] hover:border-accent-ice/20 transition-all duration-500">
            <h3 class="text-white font-bold mb-2 group-hover:text-accent-ice transition-colors">{item.title}</h3>
            <p class="text-slate-500 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>

  </section>
</BaseLayout>

<script>
  // Simple scroll reveals
  const revealElements = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        (entry.target as HTMLElement).style.opacity = '1';
        (entry.target as HTMLElement).style.transform = 'translateY(0)';
      }
    });
  }, { threshold: 0.1 });

  revealElements.forEach((el) => {
    (el as HTMLElement).style.opacity = '0';
    (el as HTMLElement).style.transform = 'translateY(20px)';
    (el as HTMLElement).style.transition = 'all 0.8s cubic-bezier(0.16, 1, 0.3, 1)';
    observer.observe(el);
  });
</script>
