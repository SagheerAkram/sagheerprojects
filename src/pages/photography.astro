---
// src/pages/photography.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import { photos, categories } from '../data/photography.js';
import { Image } from 'astro:assets';

// Load all images from the photography assets folder
const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/photography/*.{jpeg,jpg,png,gif}');

// Pre-match images with their data objects for the Image component
const galleryPhotos = await Promise.all(photos.map(async (photo) => {
  const imagePath = `/src/assets${photo.src}`;
  if (!images[imagePath]) {
    console.warn(`Image not found: ${imagePath}`);
    return { ...photo, imageImport: null };
  }
  const imageImport = await images[imagePath]();
  return { ...photo, imageImport: imageImport.default };
}));
---

<BaseLayout
  title="Visual Reflections // Sagheer Akram"
  description="A personal archive of light and silence. Photography by Sagheer Akram."
>
  <section class="relative z-10 max-w-7xl mx-auto px-6 pt-32 pb-24">

    <!-- Header -->
    <div class="mb-20">
      <span class="hero-eyebrow tracking-[0.3em] text-accent-ice opacity-60">VISUAL ARTIFACTS // STILLNESS</span>
      <h1 class="text-5xl md:text-7xl font-black text-white tracking-tighter leading-none mt-6 mb-10">
        Visual Reflections.
      </h1>
      <div class="grid md:grid-cols-2 gap-12">
        <p class="text-slate-400 leading-relaxed text-lg">
          The camera lets me see things I usually walk past. A slow shutter for a waterfall, or catching the light hitting an old building at 3 AM. It’s my way of slowing down time.
        </p>
        <p class="text-slate-500 leading-relaxed text-lg italic">
          "I don’t care about perfect composition. I care about how a place felt when I was standing there. These are the moments I wanted to keep."
        </p>
      </div>
    </div>

    <!-- Filter tabs -->
    <div class="flex flex-wrap gap-4 mb-16" id="filter-tabs">
      {categories.map((cat) => (
        <button
          class={`px-6 py-2 text-xs font-bold tracking-widest uppercase border rounded-full transition-all duration-300 ${
            cat === 'All' 
            ? 'bg-accent-ice text-black border-accent-ice' 
            : 'text-slate-500 border-white/10 hover:border-white/30 hover:text-white'
          }`}
          data-filter={cat}
        >
          {cat}
        </button>
      ))}
    </div>

    <!-- Gallery grid -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org/",
      "@type": "ImageGallery",
      "name": "Sagheer Akram's Photography Portfolio",
      "description": "A collection of architectural, natural, and urban photography by Sagheer Akram.",
      "author": {
        "@type": "Person",
        "name": "Sagheer Akram"
      },
      "image": photos.map(photo => ({
        "@type": "ImageObject",
        "contentUrl": `https://sagheerprojects.fun${photo.src}`,
        "name": photo.title,
        "caption": photo.description,
        "keywords": [photo.category, "Sagheer Akram", "Photography"]
      }))
    })} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [{
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://sagheerprojects.fun"
      },{
        "@type": "ListItem",
        "position": 2,
        "name": "Photography",
        "item": "https://sagheerprojects.fun/photography"
      }]
    })} />

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="gallery">
      {galleryPhotos.map((photo) => (
        <div
          class="gallery-item group relative aspect-[4/5] rounded-2xl overflow-hidden bg-white/5 cursor-pointer touch-manipulation"
          data-category={photo.category}
          data-id={photo.id}
          onclick="this.classList.toggle('active-touch')"
        >
          {photo.imageImport ? (
            <Image
              src={photo.imageImport}
              alt={`${photo.title} - ${photo.category} photography by Sagheer Akram`}
              width={800}
              height={1000}
              class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-1000 scale-100 group-hover:scale-105"
            />
          ) : (
            <img
              src={photo.src}
              alt={photo.title}
              class="w-full h-full object-cover grayscale"
            />
          )}

          <!-- Status Badge -->
          <div class="absolute top-4 right-4 z-20">
            <span class="px-3 py-1 bg-black/40 backdrop-blur-md border border-white/10 rounded-full text-[10px] font-bold tracking-widest text-accent-ice flex items-center gap-1.5 shadow-2xl">
              <span class="w-1 h-1 rounded-full bg-accent-ice animate-pulse"></span>
              {photo.status || 'STABLE'}
            </span>
          </div>

          <div class="inner-content absolute inset-x-0 bottom-0 p-8 translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-500 bg-gradient-to-t from-black/80 via-black/40 to-transparent group-[.active-touch]:translate-y-0 group-[.active-touch]:opacity-100">
            <span class="text-[10px] uppercase tracking-widest text-accent-ice/80 mb-2 block">{photo.category}</span>
            <h3 class="text-white font-bold text-xl mb-2 tracking-tight">{photo.title}</h3>
            <p class="text-white/60 text-sm leading-relaxed">{photo.description}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Closing text -->
    <div class="mt-24 text-center border-t border-white/[0.05] pt-16">
        <p class="text-slate-500 italic">"Captured during late-night walks, quiet Sundays, and the moments when the world felt still."</p>
    </div>

  </section>
</BaseLayout>

<script>
  // Filter logic
  const tabs = document.querySelectorAll<HTMLButtonElement>('[data-filter]');
  const items = document.querySelectorAll<HTMLElement>('.gallery-item');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const filter = tab.dataset.filter || 'All';

      // Update active tab styles
      tabs.forEach(t => {
        t.classList.remove('bg-accent-ice', 'text-black', 'border-accent-ice');
        t.classList.add('text-slate-500', 'border-white/10');
      });
      tab.classList.remove('text-slate-500', 'border-white/10');
      tab.classList.add('bg-accent-ice', 'text-black', 'border-accent-ice');

      // Show/hide items
      items.forEach(item => {
        const cat = item.dataset.category || '';
        const show = filter === 'All' || cat === filter;
        
        if (show) {
          item.style.display = 'block';
          setTimeout(() => {
            item.style.opacity = '1';
            item.style.transform = 'translateY(0) scale(1)';
          }, 10);
        } else {
          item.style.opacity = '0';
          item.style.transform = 'translateY(10px) scale(0.98)';
          setTimeout(() => {
            if (item.style.opacity === '0') item.style.display = 'none';
          }, 400);
        }
      });
    });
  });

  // Entrance animation
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry, i) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          observer.unobserve(entry.target);
        }
      });
    },
    { 
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px' 
    }
  );

  items.forEach((item, i) => {
    item.classList.add('reveal');
    (item as HTMLElement).style.transitionDelay = `${i % 3 * 0.1}s`;
    observer.observe(item);
  });
</script>
